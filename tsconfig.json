{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "backend/**/*.js",
    "packages/**/*.js",
    "proxy/**/*.js",
    "eslint.config.js"
  ],
  "exclude": [
    "**/node_modules/**",
    "**/.next/**",
    "**/coverage/**"
  ]
}
